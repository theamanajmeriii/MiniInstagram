<%- include('../partials/header') %>

<div class="layout">
  <div class="feed">

    <div class="post" style="padding: 20px;">

      <h2 style="margin-bottom: 20px;">Create New Post</h2>

      <form action="/posts" method="POST" class="edit-form">

        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" required>
        </div>

        <div class="form-group">
          <label>Image URL</label>
          <input type="text" name="image" required>
        </div>

        <div class="form-group">
          <label>Caption</label>
          <textarea name="caption" required></textarea>
        </div>

        <button type="submit" class="button-link">Create Post</button>

      </form>

      <br>
      <a href="/posts" class="follow-btn">Back</a>

    </div>

  </div>
</div>

<%- include('../partials/footer') %>

